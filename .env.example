# =============================================================================
# Hotel Yuvaan Backoffice — environment templates
# =============================================================================
# Committed files:
#   .env.dev   → remote dev API  (npm run dev / build:dev)
#   .env.local → localhost API    (npm run dev:local / build:local)
#   .env.prod  → production API   (npm run build:prod)
#
# Personal overrides (gitignored via .env.*.local):
#   .env.local.local → optional machine-specific tweaks for local mode
#
# Default deployment (Vercel `pnpm build`) uses .env.dev
# Production deployment: set build command to `pnpm build:prod`
# =============================================================================

# --- .env.dev ---
# VITE_APP_ENV=dev
# VITE_BACKEND_API_URL=https://dev-api.hotelyuvaan.com
# VITE_API_VERSION_PATH=/api/v1.0.0

# --- .env.local ---
# VITE_APP_ENV=dev
# VITE_BACKEND_API_URL=http://localhost:8080
# VITE_API_VERSION_PATH=/api/v1.0.0

# --- .env.prod ---
# VITE_APP_ENV=prod
# VITE_BACKEND_API_URL=https://api.hotelyuvaan.com
# VITE_API_VERSION_PATH=/api/v1.0.0
